#!/usr/bin/env bash
# Block commits that contain obvious secret patterns. Enable with:
#   git config core.hooksPath .githooks
set -eu

# Patterns to catch — extend as needed.
patterns='sk-ant-api03-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9]{32,}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|AKIA[A-Z0-9]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'

# Staged file paths (added/copied/modified, no deletions).
mapfile -t files < <(git diff --cached --name-only --diff-filter=ACM)

leaked=0
for f in "${files[@]}"; do
  # Skip binaries and the example/template/hook itself.
  case "$f" in
    *.env.example|.githooks/*|*.png|*.jpg|*.pdf|*.zip) continue ;;
  esac
  if git show ":$f" 2>/dev/null | grep -EnH "$patterns" >&2; then
    echo "  ↑ secret-like pattern in $f" >&2
    leaked=1
  fi
done

if [ "$leaked" -ne 0 ]; then
  echo
  echo "✗ Commit blocked: staged content matches secret patterns." >&2
  echo "  If this is a false positive, edit .githooks/pre-commit or run with --no-verify (NOT recommended)." >&2
  exit 1
fi
